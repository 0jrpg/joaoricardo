# Senha única de acesso ao /admin
ADMIN_PASSWORD=escolha-uma-senha-forte

# Token do GitHub com permissão de escrita no repositório dos PDFs
# (Settings > Developer settings > Fine-grained tokens > Contents: Read and write)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Dono e nome do repositório onde os PDFs ficam
GITHUB_OWNER=seu-usuario-github
GITHUB_REPO=meus-pdfs

# Branch usada (normalmente "main")
GITHUB_BRANCH=main

# Pasta dentro do repo onde os arquivos são guardados (aceita qualquer tipo)
GITHUB_FILES_PATH=files
